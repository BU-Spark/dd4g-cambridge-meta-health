# Cambridge ODP Evaluation Pipeline - Configuration Template
# Copy this file to .env and fill in your API keys
#
# IMPORTANT: Never commit .env to git! It contains sensitive credentials.
# The .env file is automatically excluded via .gitignore

# ────────────────────────────────────────────────────────────
# LLM PROVIDER CONFIGURATION
# ────────────────────────────────────────────────────────────

# LLM provider to use: 'gemini', 'openai', or 'anthropic'
# This determines which AI service will evaluate dataset metadata
LLM_PROVIDER=gemini

# ────────────────────────────────────────────────────────────
# GEMINI CONFIGURATION
# ────────────────────────────────────────────────────────────

# Google AI API key (required if LLM_PROVIDER=gemini)
# Get your key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Gemini model to use (default: gemini-2.0-flash)
# Options:
#   - gemini-2.0-flash     (Fast and cost-effective)
#   - gemini-1.5-pro       (Advanced reasoning)
#   - gemini-1.5-flash     (Balanced performance)
GEMINI_MODEL=gemini-2.0-flash

# ────────────────────────────────────────────────────────────
# OPENAI CONFIGURATION
# ────────────────────────────────────────────────────────────

# OpenAI API key (required if LLM_PROVIDER=openai)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI model to use (default: gpt-4)
# Options: gpt-4, gpt-4-turbo-preview, gpt-3.5-turbo, gpt-4o
# Recommendation: gpt-4 for best quality, gpt-3.5-turbo for cost savings
OPENAI_MODEL=gpt-4

# ────────────────────────────────────────────────────────────
# ANTHROPIC CONFIGURATION
# ────────────────────────────────────────────────────────────

# Anthropic API key (required if LLM_PROVIDER=anthropic)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Anthropic model to use (default: claude-3-sonnet-20240229)
# Options:
#   - claude-3-opus-20240229    (Most capable, highest cost)
#   - claude-3-sonnet-20240229  (Balanced performance/cost)
#   - claude-3-haiku-20240307   (Fastest, lowest cost)
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# ────────────────────────────────────────────────────────────
# LLM PARAMETERS
# ────────────────────────────────────────────────────────────

# Temperature (0.0-1.0): Lower values = more deterministic responses
# Recommendation: 0.3 for consistent metadata evaluation
LLM_TEMPERATURE=0.3

# Maximum tokens in LLM response
# Each evaluation should return JSON with scores, so 1000 tokens is sufficient
LLM_MAX_TOKENS=1000
